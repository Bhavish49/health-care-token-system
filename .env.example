# Environment Setup
# Copy this file to .env and fill in the values before running the project

# Supabase Configuration
# You can find these in your Supabase Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Note for Frontend Use:
# In the vanilla JS setup, these variables are typically set in js/services/supabase.js
# However, if migrating to a bundler (like Vite or Webpack), they should be accessed via:
# VITE_SUPABASE_URL / process.env.SUPABASE_URL
